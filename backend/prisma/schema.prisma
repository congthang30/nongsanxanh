// Prisma schema - NongSan Xanh Store-Chain MVP (Bach Hoa Xanh model)
// Tien te: Int (VND). Ton kho: Decimal (kg/gram). PK: UUID.
// Source of truth: BACH_HOA_XANH_STORE_MVP_SPEC.md
//
// Mo hinh: chuoi cua hang noi bo theo khu vuc. KHONG con marketplace seller.
//   - Store: cua hang noi bo (thay Supplier/Shop cu)
//   - StoreStaff: nhan vien cua hang (manager/staff/warehouse/shipper)
//   - StoreServiceArea: khu vuc phuc vu cua cua hang
//   - StoreInventory: ton kho cua tung cua hang
//   - Order.storeId: don gan truc tiep cho cua hang
//   - Delivery.shipperId: giao truc tiep cho shipper chinh cua cua hang

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// IDENTITY & ACCESS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING
}

model User {
  id              String     @id @default(uuid())
  email           String?    @unique
  phone           String?    @unique
  passwordHash    String?    @map("password_hash")
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  profile         UserProfile?
  addresses       Address[]
  userRoles       UserRole[]
  refreshTokens   RefreshToken[]
  carts           Cart[]
  orders          Order[]
  reviews         Review[]
  notifications   Notification[]
  supportTickets  SupportTicket[]
  aiConversations AiConversation[]

  // Store-chain relations
  managedStore     Store?       @relation("StoreManager")
  shipperStore     Store?       @relation("StorePrimaryShipper")
  storeMemberships StoreStaff[]
  deliveries       Delivery[]   @relation("DeliveryShipper")
  auditLogs        AuditLog[]

  // POS relations
  posSalesAsCashier POSSale[]      @relation("POSSaleCashier")
  cashierShifts     CashierShift[] @relation("CashierShiftCashier")
  posReturnsCreated POSReturn[]    @relation("POSReturnCashier")

  @@map("users")
}

model UserProfile {
  id        String    @id @default(uuid())
  userId    String    @unique @map("user_id")
  fullName  String    @map("full_name")
  avatarUrl String?   @map("avatar_url")
  dob       DateTime?
  gender    String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Address {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  recipientName     String   @map("recipient_name")
  phone             String
  province          String
  district          String
  ward              String
  line1             String
  note              String?
  formattedAddress  String?  @map("formatted_address")
  placeId           String?  @map("place_id")
  lat               Float?
  lng               Float?
  geocodeProvider   String?  @map("geocode_provider")
  geocodeConfidence Float?   @map("geocode_confidence")
  deliveryNote      String?  @map("delivery_note")
  isDefault         Boolean  @default(false) @map("is_default")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String           @id @default(uuid())
  code     String           @unique
  resource String
  action   String
  roles    RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String  @map("user_id")
  roleId    String  @map("role_id")
  scopeType String? @map("scope_type")
  scopeId   String? @map("scope_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  sessionId String    @map("session_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpCode {
  id           String    @id @default(uuid())
  target       String
  purpose      String
  codeHash     String    @map("code_hash")
  expiresAt    DateTime  @map("expires_at")
  attemptCount Int       @default(0) @map("attempt_count")
  consumedAt   DateTime? @map("consumed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([target, purpose])
  @@map("otp_codes")
}

// ============================================================
// STORE CHAIN (cua hang noi bo theo khu vuc)
// ============================================================

enum StoreStatus {
  ACTIVE
  PAUSED
  CLOSED
  SUSPENDED
}

enum StoreStaffRole {
  STORE_MANAGER
  STORE_STAFF
  WAREHOUSE_STAFF
  SHIPPER
}

enum StoreStaffStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Store {
  id               String      @id @default(uuid())
  code             String      @unique
  name             String
  slug             String      @unique
  status           StoreStatus @default(ACTIVE)
  phone            String?
  email            String?
  addressLine      String?     @map("address_line")
  formattedAddress String?     @map("formatted_address")
  province         String
  district         String?
  ward             String?
  lat              Float?
  lng              Float?
  serviceRadiusKm  Float?      @map("service_radius_km")
  openTime         String?     @map("open_time")
  closeTime        String?     @map("close_time")
  prepareMinutes   Int         @default(45) @map("prepare_minutes")
  managerId        String?     @unique @map("manager_id")
  primaryShipperId String?     @unique @map("primary_shipper_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  manager               User?                  @relation("StoreManager", fields: [managerId], references: [id])
  primaryShipper        User?                  @relation("StorePrimaryShipper", fields: [primaryShipperId], references: [id])
  staff                 StoreStaff[]
  serviceAreas          StoreServiceArea[]
  inventory             StoreInventory[]
  inventoryTransactions InventoryTransaction[]
  orders                Order[]
  deliveries            Delivery[]
  coupons               Coupon[]
  posSales              POSSale[]
  cashierShifts         CashierShift[]
  posReturns            POSReturn[]

  @@index([status])
  @@index([province, district])
  @@map("stores")
}

model StoreStaff {
  id       String           @id @default(uuid())
  storeId  String           @map("store_id")
  userId   String           @map("user_id")
  role     StoreStaffRole
  status   StoreStaffStatus @default(ACTIVE)
  joinedAt DateTime         @default(now()) @map("joined_at")
  leftAt   DateTime?        @map("left_at")
  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([userId, status])
  @@index([storeId, role, status])
  @@map("store_staff")
}

model StoreServiceArea {
  id          String   @id @default(uuid())
  storeId     String   @map("store_id")
  province    String
  district    String?
  ward        String?
  polygonJson Json?    @map("polygon_json")
  radiusKm    Float?   @map("radius_km")
  priority    Int      @default(0)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now()) @map("created_at")
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([province, district, ward])
  @@map("store_service_areas")
}

// ============================================================
// CATALOG
// ============================================================

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

/// Cach ban variant: UNIT = dem chiec/hop/bo; WEIGHT = can ky, nhap khoi luong.
enum VariantSaleMode {
  UNIT
  WEIGHT
}

enum BarcodeType {
  EAN13
  UPC
  CODE128
  INTERNAL
  SCALE_LABEL
}

enum BarcodeStatus {
  ACTIVE
  INACTIVE
}

model Category {
  id        String     @id @default(uuid())
  parentId  String?    @map("parent_id")
  name      String
  slug      String     @unique
  status    String     @default("ACTIVE")
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id                 String        @id @default(uuid())
  categoryId         String        @map("category_id")
  name               String
  slug               String        @unique
  description        String?
  status             ProductStatus @default(ACTIVE)
  originRegion       String?       @map("origin_region")
  storageInstruction String?       @map("storage_instruction")
  shelfLifeDays      Int?          @map("shelf_life_days")
  ratingAvg          Float         @default(0) @map("rating_avg")
  ratingCount        Int           @default(0) @map("rating_count")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")

  category   Category           @relation(fields: [categoryId], references: [id])
  variants   ProductVariant[]
  images     ProductImage[]
  attributes ProductAttribute[]
  reviews    Review[]

  @@index([status, categoryId])
  @@map("products")
}

model ProductVariant {
  id                   String          @id @default(uuid())
  productId            String          @map("product_id")
  sku                  String          @unique
  unit                 String
  unitValue            Decimal         @map("unit_value") @db.Decimal(10, 3)
  packageType          String?         @map("package_type")
  price                Int
  compareAtPrice       Int?            @map("compare_at_price")
  barcode              String?
  saleMode             VariantSaleMode @default(UNIT) @map("sale_mode")
  allowDecimalQuantity Boolean         @default(false) @map("allow_decimal_quantity")
  status               String          @default("ACTIVE")
  product              Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartItems        CartItem[]
  orderItems       OrderItem[]
  priceHistories   PriceHistory[]
  campaignItems    CampaignItem[]
  comboItems       ComboItem[]
  storeInventories StoreInventory[]
  barcodes         ProductBarcode[]
  posSaleItems     POSSaleItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  url       String
  alt       String?
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductAttribute {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  key       String
  value     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_attributes")
}

model PriceHistory {
  id             String         @id @default(uuid())
  variantId      String         @map("variant_id")
  price          Int
  compareAtPrice Int?           @map("compare_at_price")
  startsAt       DateTime       @map("starts_at")
  endsAt         DateTime?      @map("ends_at")
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("price_histories")
}

// ============================================================
// STORE INVENTORY (ton kho cua tung cua hang)
// ============================================================

enum StoreInventoryStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum InventoryTxType {
  IMPORT
  EXPORT
  RESERVE
  RELEASE
  COMMIT
  ADJUST
  POS_SALE
  POS_RETURN
  POS_LOSS
}

model StoreInventory {
  id                String               @id @default(uuid())
  storeId           String               @map("store_id")
  variantId         String               @map("variant_id")
  quantityOnHand    Decimal              @default(0) @map("quantity_on_hand") @db.Decimal(12, 3)
  reservedQuantity  Decimal              @default(0) @map("reserved_quantity") @db.Decimal(12, 3)
  lowStockThreshold Decimal              @default(0) @map("low_stock_threshold") @db.Decimal(12, 3)
  priceOverride     Int?                 @map("price_override")
  salePrice         Int?                 @map("sale_price")
  status            StoreInventoryStatus @default(ACTIVE)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  store             Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant           ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([storeId, variantId])
  @@index([storeId, status])
  @@index([variantId])
  @@map("store_inventories")
}

model InventoryTransaction {
  id        String          @id @default(uuid())
  storeId   String          @map("store_id")
  variantId String          @map("variant_id")
  type      InventoryTxType
  quantity  Decimal         @db.Decimal(12, 3)
  beforeQty Decimal         @map("before_qty") @db.Decimal(12, 3)
  afterQty  Decimal         @map("after_qty") @db.Decimal(12, 3)
  reason    String?
  orderId   String?         @map("order_id")
  createdBy String?         @map("created_by")
  createdAt DateTime        @default(now()) @map("created_at")
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, variantId])
  @@index([orderId])
  @@map("inventory_transactions")
}

// ============================================================
// CART & ORDER
// ============================================================

model Cart {
  id        String     @id @default(uuid())
  userId    String?    @map("user_id")
  sessionId String?    @map("session_id")
  storeId   String?    @map("store_id")
  status    String     @default("ACTIVE")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]

  @@index([userId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        String         @id @default(uuid())
  cartId    String         @map("cart_id")
  variantId String         @map("variant_id")
  quantity  Decimal        @db.Decimal(12, 3)
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

enum OrderStatus {
  PENDING_PAYMENT
  PLACED
  STORE_CONFIRMED
  PICKING
  PACKED
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  DELIVERY_FAILED
  RETURN_REQUESTED
  RETURNED
}

enum PaymentStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUND_PENDING
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  COD
  VNPAY
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique @map("order_number")
  userId        String        @map("user_id")
  storeId       String        @map("store_id")
  shipperId     String?       @map("shipper_id")
  status        OrderStatus   @default(PENDING_PAYMENT)
  paymentStatus PaymentStatus @default(INITIATED) @map("payment_status")
  paymentMethod PaymentMethod @map("payment_method")
  subtotal      Int           @default(0)
  discountTotal Int           @default(0) @map("discount_total")
  shippingFee   Int           @default(0) @map("shipping_fee")
  grandTotal    Int           @default(0) @map("grand_total")

  recipientName   String  @map("recipient_name")
  recipientPhone  String  @map("recipient_phone")
  deliveryAddress String  @map("delivery_address")
  deliveryLat     Float?  @map("delivery_lat")
  deliveryLng     Float?  @map("delivery_lng")
  deliveryNote    String? @map("delivery_note")

  assignmentDistanceKm Float?   @map("assignment_distance_km")
  assignmentReason     String?  @map("assignment_reason")
  note                 String?
  couponCode           String?  @map("coupon_code")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user           User                 @relation(fields: [userId], references: [id])
  store          Store                @relation(fields: [storeId], references: [id])
  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  payments       Payment[]
  delivery       Delivery?
  returnRequests ReturnRequest[]
  supportTickets SupportTicket[]

  @@index([userId, createdAt])
  @@index([storeId, status, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id                  String         @id @default(uuid())
  orderId             String         @map("order_id")
  productId           String         @map("product_id")
  variantId           String         @map("variant_id")
  productNameSnapshot String         @map("product_name_snapshot")
  skuSnapshot         String         @map("sku_snapshot")
  unitSnapshot        String         @map("unit_snapshot")
  unitPrice           Int            @map("unit_price")
  quantity            Decimal        @db.Decimal(12, 3)
  quantityPicked      Decimal?       @map("quantity_picked") @db.Decimal(12, 3)
  lineTotal           Int            @map("line_total")
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant             ProductVariant @relation(fields: [variantId], references: [id])
  reviews             Review[]
  returnItems         ReturnItem[]

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id         String       @id @default(uuid())
  orderId    String       @map("order_id")
  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus  @map("to_status")
  reason     String?
  actorId    String?      @map("actor_id")
  createdAt  DateTime     @default(now()) @map("created_at")
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model ReturnRequest {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  userId      String       @map("user_id")
  status      String       @default("REQUESTED")
  reason      String
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  order       Order        @relation(fields: [orderId], references: [id])
  items       ReturnItem[]

  @@index([orderId])
  @@map("return_requests")
}

model ReturnItem {
  id              String        @id @default(uuid())
  returnRequestId String        @map("return_request_id")
  orderItemId     String        @map("order_item_id")
  quantity        Decimal       @db.Decimal(12, 3)
  resolution      String?
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])

  @@map("return_items")
}

// ============================================================
// PAYMENT
// ============================================================

model Payment {
  id           String               @id @default(uuid())
  orderId      String               @map("order_id")
  method       String
  provider     String?
  amount       Int
  status       PaymentStatus        @default(INITIATED)
  paidAt       DateTime?            @map("paid_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  order        Order                @relation(fields: [orderId], references: [id])
  transactions PaymentTransaction[]
  refunds      Refund[]

  @@index([orderId, status])
  @@map("payments")
}

model PaymentTransaction {
  id                    String   @id @default(uuid())
  paymentId             String   @map("payment_id")
  providerTransactionId String?  @unique @map("provider_transaction_id")
  idempotencyKey        String?  @unique @map("idempotency_key")
  requestPayload        Json?    @map("request_payload")
  callbackPayload       Json?    @map("callback_payload")
  status                String
  createdAt             DateTime @default(now()) @map("created_at")
  payment               Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_transactions")
}

model Refund {
  id          String    @id @default(uuid())
  paymentId   String    @map("payment_id")
  orderId     String    @map("order_id")
  amount      Int
  status      String    @default("PENDING")
  reason      String?
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  payment     Payment   @relation(fields: [paymentId], references: [id])

  @@map("refunds")
}

// ============================================================
// DELIVERY (giao truc tiep boi shipper chinh cua store)
// ============================================================

enum DeliveryStatus {
  ASSIGNED
  PICKED_FROM_STORE
  OUT_FOR_DELIVERY
  ARRIVED_AT_CUSTOMER
  DELIVERED
  FAILED
}

model Delivery {
  id             String          @id @default(uuid())
  orderId        String          @unique @map("order_id")
  storeId        String          @map("store_id")
  shipperId      String          @map("shipper_id")
  status         DeliveryStatus  @default(ASSIGNED)
  pickupName     String?         @map("pickup_name")
  pickupAddress  String?         @map("pickup_address")
  pickupLat      Float?          @map("pickup_lat")
  pickupLng      Float?          @map("pickup_lng")
  dropoffName    String?         @map("dropoff_name")
  dropoffPhone   String?         @map("dropoff_phone")
  dropoffAddress String?         @map("dropoff_address")
  dropoffLat     Float?          @map("dropoff_lat")
  dropoffLng     Float?          @map("dropoff_lng")
  distanceKm     Float?          @map("distance_km")
  codAmount      Int?            @map("cod_amount")
  codCollected   Boolean         @default(false) @map("cod_collected")
  failureReason  String?         @map("failure_reason")
  pickedAt       DateTime?       @map("picked_at")
  deliveredAt    DateTime?       @map("delivered_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store          Store           @relation(fields: [storeId], references: [id])
  shipper        User            @relation("DeliveryShipper", fields: [shipperId], references: [id])
  events         DeliveryEvent[]

  @@index([shipperId, status])
  @@index([storeId, status])
  @@map("deliveries")
}

model DeliveryEvent {
  id         String         @id @default(uuid())
  deliveryId String         @map("delivery_id")
  status     DeliveryStatus
  note       String?
  actorId    String?        @map("actor_id")
  createdAt  DateTime       @default(now()) @map("created_at")
  delivery   Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@map("delivery_events")
}

// ============================================================
// REVIEW
// ============================================================

model Review {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  productId   String        @map("product_id")
  orderItemId String        @map("order_item_id")
  rating      Int
  comment     String?
  status      String        @default("ACTIVE")
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User          @relation(fields: [userId], references: [id])
  product     Product       @relation(fields: [productId], references: [id])
  orderItem   OrderItem     @relation(fields: [orderItemId], references: [id])
  images      ReviewImage[]

  @@unique([orderItemId, userId])
  @@index([productId, status, createdAt])
  @@map("reviews")
}

model ReviewImage {
  id       String @id @default(uuid())
  reviewId String @map("review_id")
  url      String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

// ============================================================
// PROMOTION (PLATFORM hoac STORE scope - khong con voucher seller)
// ============================================================

enum CouponScope {
  PLATFORM
  STORE
}

model Coupon {
  id            String             @id @default(uuid())
  code          String             @unique
  name          String?
  scope         CouponScope        @default(PLATFORM)
  storeId       String?            @map("store_id")
  type          String
  value         Int
  maxDiscount   Int?               @map("max_discount")
  minOrderValue Int                @default(0) @map("min_order_value")
  startsAt      DateTime           @map("starts_at")
  endsAt        DateTime           @map("ends_at")
  usageLimit    Int?               @map("usage_limit")
  usageCount    Int                @default(0) @map("usage_count")
  perUserLimit  Int?               @map("per_user_limit")
  status        String             @default("ACTIVE")
  createdBy     String?            @map("created_by")
  createdAt     DateTime           @default(now()) @map("created_at")
  store         Store?             @relation(fields: [storeId], references: [id])
  redemptions   CouponRedemption[]

  @@index([scope, storeId, status])
  @@map("coupons")
}

model CouponRedemption {
  id             String   @id @default(uuid())
  couponId       String   @map("coupon_id")
  userId         String   @map("user_id")
  orderId        String   @map("order_id")
  discountAmount Int      @map("discount_amount")
  createdAt      DateTime @default(now()) @map("created_at")
  coupon         Coupon   @relation(fields: [couponId], references: [id])

  @@unique([couponId, userId, orderId])
  @@index([couponId, userId])
  @@map("coupon_redemptions")
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model NotificationTemplate {
  id      String  @id @default(uuid())
  code    String  @unique
  channel String
  subject String?
  body    String
  locale  String  @default("vi")

  @@map("notification_templates")
}

// ============================================================
// SUPPORT / TICKET
// ============================================================

model SupportTicket {
  id         String          @id @default(uuid())
  code       String          @unique
  userId     String          @map("user_id")
  orderId    String?         @map("order_id")
  subject    String
  status     String          @default("OPEN")
  priority   String          @default("NORMAL")
  assignedTo String?         @map("assigned_to")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  user       User            @relation(fields: [userId], references: [id])
  order      Order?          @relation(fields: [orderId], references: [id])
  messages   TicketMessage[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String        @map("ticket_id")
  senderId   String?       @map("sender_id")
  senderRole String        @map("sender_role")
  body       String
  createdAt  DateTime      @default(now()) @map("created_at")
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

// ============================================================
// CAMPAIGN / FLASH SALE / COMBO
// ============================================================

enum CampaignStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

model Campaign {
  id        String         @id @default(uuid())
  name      String
  slug      String         @unique
  type      String         @default("FLASH_SALE")
  startsAt  DateTime       @map("starts_at")
  endsAt    DateTime       @map("ends_at")
  status    CampaignStatus @default(SCHEDULED)
  createdAt DateTime       @default(now()) @map("created_at")
  items     CampaignItem[]

  @@map("campaigns")
}

model CampaignItem {
  id            String         @id @default(uuid())
  campaignId    String         @map("campaign_id")
  variantId     String         @map("variant_id")
  salePrice     Int            @map("sale_price")
  quantityLimit Int?           @map("quantity_limit")
  soldCount     Int            @default(0) @map("sold_count")
  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([campaignId, variantId])
  @@map("campaign_items")
}

model Combo {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  imageUrl    String?     @map("image_url")
  price       Int
  status      String      @default("ACTIVE")
  createdAt   DateTime    @default(now()) @map("created_at")
  items       ComboItem[]

  @@map("combos")
}

model ComboItem {
  id        String         @id @default(uuid())
  comboId   String         @map("combo_id")
  variantId String         @map("variant_id")
  quantity  Decimal        @db.Decimal(12, 3)
  combo     Combo          @relation(fields: [comboId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("combo_items")
}

// ============================================================
// AI CHATBOT (RAG)
// ============================================================

model AiConversation {
  id        String      @id @default(uuid())
  userId    String?     @map("user_id")
  sessionId String?     @map("session_id")
  createdAt DateTime    @default(now()) @map("created_at")
  user      User?       @relation(fields: [userId], references: [id])
  messages  AiMessage[]

  @@index([userId])
  @@index([sessionId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String         @map("conversation_id")
  role           String
  content        String
  createdAt      DateTime       @default(now()) @map("created_at")
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model AiDocument {
  id         String            @id @default(uuid())
  title      String
  sourceType String            @map("source_type")
  sourceRef  String?           @map("source_ref")
  content    String
  createdAt  DateTime          @default(now()) @map("created_at")
  chunks     AiDocumentChunk[]

  @@map("ai_documents")
}

model AiDocumentChunk {
  id         String     @id @default(uuid())
  documentId String     @map("document_id")
  chunkIndex Int        @map("chunk_index")
  content    String
  embedding  Json?
  createdAt  DateTime   @default(now()) @map("created_at")
  document   AiDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("ai_document_chunks")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  actorId    String?  @map("actor_id")
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  storeId    String?  @map("store_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

// ============================================================
// POS - BAN HANG TAI QUAY (Point of Sale)
// Source of truth: STORE_POS_CHECKOUT_SPEC.md
// Luong offline in-store: cashier quet barcode -> tinh tien -> thanh toan
// -> tru ton kho cua hang ngay (InventoryTransaction type POS_SALE).
// KHONG co delivery, KHONG resolve store theo dia chi, KHONG multi-store.
// ============================================================

model ProductBarcode {
  id        String         @id @default(uuid())
  variantId String         @map("variant_id")
  barcode   String         @unique
  type      BarcodeType    @default(EAN13)
  isPrimary Boolean        @default(false) @map("is_primary")
  status    BarcodeStatus  @default(ACTIVE)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, status])
  @@map("product_barcodes")
}

enum POSSaleStatus {
  DRAFT
  HELD
  PAID
  VOIDED
  REFUNDED
  PARTIAL_REFUNDED
}

enum POSPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum POSPaymentMethod {
  CASH
  BANK_TRANSFER_MANUAL
  CARD
  VNPAY
  MOMO
  ZALOPAY
}

enum POSPaymentRecordStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum CashierShiftStatus {
  OPEN
  CLOSED
}

enum POSReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

model CashierShift {
  id             String             @id @default(uuid())
  storeId        String             @map("store_id")
  cashierId      String             @map("cashier_id")
  openedAt       DateTime           @default(now()) @map("opened_at")
  closedAt       DateTime?          @map("closed_at")
  openingCash    Int                @default(0) @map("opening_cash")
  expectedCash   Int                @default(0) @map("expected_cash")
  countedCash    Int?               @map("counted_cash")
  cashDifference Int?               @map("cash_difference")
  status         CashierShiftStatus @default(OPEN)
  note           String?
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  store          Store              @relation(fields: [storeId], references: [id])
  cashier        User               @relation("CashierShiftCashier", fields: [cashierId], references: [id])
  sales          POSSale[]

  @@index([storeId, status])
  @@index([cashierId, status])
  @@map("cashier_shifts")
}

model POSSale {
  id                    String           @id @default(uuid())
  saleNumber            String           @unique @map("sale_number")
  storeId               String           @map("store_id")
  cashierId             String           @map("cashier_id")
  shiftId               String?          @map("shift_id")
  customerId            String?          @map("customer_id")
  customerPhoneSnapshot String?          @map("customer_phone_snapshot")
  status                POSSaleStatus    @default(DRAFT)
  subtotal              Int              @default(0)
  discountTotal         Int              @default(0) @map("discount_total")
  taxTotal              Int              @default(0) @map("tax_total")
  grandTotal            Int              @default(0) @map("grand_total")
  amountPaid            Int              @default(0) @map("amount_paid")
  changeAmount          Int              @default(0) @map("change_amount")
  paymentStatus         POSPaymentStatus @default(PENDING) @map("payment_status")
  note                  String?
  paidAt                DateTime?        @map("paid_at")
  voidedAt              DateTime?        @map("voided_at")
  voidReason            String?          @map("void_reason")
  voidedBy              String?          @map("voided_by")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  store    Store         @relation(fields: [storeId], references: [id])
  cashier  User          @relation("POSSaleCashier", fields: [cashierId], references: [id])
  shift    CashierShift? @relation(fields: [shiftId], references: [id])
  items    POSSaleItem[]
  payments POSPayment[]
  returns  POSReturn[]

  @@index([storeId, status, createdAt])
  @@index([cashierId, createdAt])
  @@index([shiftId])
  @@map("pos_sales")
}

model POSSaleItem {
  id                  String          @id @default(uuid())
  saleId              String          @map("sale_id")
  productId           String          @map("product_id")
  variantId           String          @map("variant_id")
  barcodeSnapshot     String?         @map("barcode_snapshot")
  productNameSnapshot String          @map("product_name_snapshot")
  skuSnapshot         String          @map("sku_snapshot")
  unitSnapshot        String          @map("unit_snapshot")
  unitPrice           Int             @map("unit_price")
  quantity            Decimal         @db.Decimal(12, 3)
  discountAmount      Int             @default(0) @map("discount_amount")
  lineTotal           Int             @map("line_total")
  createdAt           DateTime        @default(now()) @map("created_at")
  sale                POSSale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant             ProductVariant  @relation(fields: [variantId], references: [id])
  returnItems         POSReturnItem[]

  @@index([saleId])
  @@map("pos_sale_items")
}

model POSPayment {
  id        String                 @id @default(uuid())
  saleId    String                 @map("sale_id")
  method    POSPaymentMethod
  amount    Int
  status    POSPaymentRecordStatus @default(PENDING)
  reference String?
  tendered  Int?
  change    Int?
  paidAt    DateTime?              @map("paid_at")
  createdAt DateTime               @default(now()) @map("created_at")
  sale      POSSale                @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("pos_payments")
}

model POSReturn {
  id             String          @id @default(uuid())
  originalSaleId String          @map("original_sale_id")
  storeId        String          @map("store_id")
  cashierId      String          @map("cashier_id")
  approvedBy     String?         @map("approved_by")
  refundAmount   Int             @default(0) @map("refund_amount")
  reason         String
  status         POSReturnStatus @default(REQUESTED)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  completedAt    DateTime?       @map("completed_at")
  store          Store           @relation(fields: [storeId], references: [id])
  cashier        User            @relation("POSReturnCashier", fields: [cashierId], references: [id])
  originalSale   POSSale         @relation(fields: [originalSaleId], references: [id])
  items          POSReturnItem[]

  @@index([storeId, status])
  @@index([originalSaleId])
  @@map("pos_returns")
}

model POSReturnItem {
  id           String      @id @default(uuid())
  returnId     String      @map("return_id")
  saleItemId   String      @map("sale_item_id")
  quantity     Decimal     @db.Decimal(12, 3)
  refundAmount Int         @map("refund_amount")
  restockable  Boolean     @default(true)
  returnRef    POSReturn   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItem     POSSaleItem @relation(fields: [saleItemId], references: [id])

  @@index([returnId])
  @@map("pos_return_items")
}
