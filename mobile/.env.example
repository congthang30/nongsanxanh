# API backend. Khi chay tren may that/emulator, doi localhost thanh IP LAN cua may chay backend.
# Android emulator: dung http://10.0.2.2:3000/api/v1
# iOS simulator:    dung http://localhost:3000/api/v1
# May that:         dung http://<LAN-IP>:3000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Map provider: google | apple | mapbox (MVP dung google tren Android, apple/google tren iOS)
EXPO_PUBLIC_MAP_PROVIDER=google

# Google Maps SDK key (can cho react-native-maps tren Android neu dung PROVIDER_GOOGLE).
# Neu trong, map van chay nhung Android co the dung provider mac dinh.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
