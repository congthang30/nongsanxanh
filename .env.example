# ============ Backend ============
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173
APP_NAME=Nông Sản Xanh
PUBLIC_APP_URL=http://localhost:5173

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://agri:agri_pass@localhost:5433/agri_db?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- AI service / vector search ----
AI_SERVICE_URL=http://localhost:8000
AI_EMBEDDING_PROVIDER=local
AI_LOCAL_EMBEDDING_MODEL=jinaai/jina-embeddings-v3
AI_CLOUD_EMBEDDING_MODEL=jina-embeddings-v3
# ai_vector_index is vector(1024); changing this requires a DB migration and full reindex.
AI_EMBEDDING_DIMENSIONS=1024
JINA_API_KEY=
AI_GENERATION_PROVIDER=none
AI_CLOUD_GENERATION_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
CHAT_MEMORY_TTL_SECONDS=604800
CHAT_MEMORY_MAX_MESSAGES=100
VECTOR_SEARCH_TOP_K=5
VECTOR_SCORE_THRESHOLD=0.62
AI_VECTOR_SYNC_DEBOUNCE_MS=10000
AI_VECTOR_SYNC_ATTEMPTS=3
AI_VECTOR_SYNC_CONCURRENCY=2
AI_VECTOR_SYNC_REMOVE_ON_COMPLETE=1000
AI_VECTOR_SYNC_REMOVE_ON_FAIL=5000
AI_VECTOR_EXPIRY_SCAN_INTERVAL_MS=900000

# ---- JWT ----
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_REFRESH_TTL=1209600

# ---- Object storage (MinIO / S3) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agri-media
S3_PUBLIC_URL=http://localhost:9000/agri-media

# ---- Mail / SMTP (gửi trực tiếp qua provider thật ở cả local và production) ----
# Ví dụ Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false.
# SMTP_PASS nên là App Password, không dùng mật khẩu đăng nhập email thông thường.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM="Nông Sản Xanh <your-email@example.com>"