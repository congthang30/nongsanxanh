# ============ Backend ============
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173
APP_NAME=Nông Sản Xanh
PUBLIC_APP_URL=http://localhost:5173

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://agri:agri_pass@localhost:5433/agri_db?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_REFRESH_TTL=1209600

# ---- Object storage (MinIO / S3) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=agri-media
S3_PUBLIC_URL=http://localhost:9000/agri-media

# ---- Mail (Mailhog dev) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Agri Shop <no-reply@agri.local>"

# ---- Google login ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- VNPay sandbox ----
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment/vnpay/return

# ============ Frontend ============
VITE_API_BASE_URL=http://localhost:3000/api/v1
